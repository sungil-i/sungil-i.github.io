---
// src/components/YearSelector.astro

const years = ['2026', '2025'];
const currentPath = Astro.url.pathname;

// 현재 접속한 URL이 배열에 있는 연도(/2026/, /2025/ 등) 중 하나로 시작하는지 확인합니다.
const isYearPage = years.some(year => currentPath.startsWith(`/${year}/`));
---

<select id="year-switcher" class="form-select form-select-sm" aria-label="연도 선택">
  <option value="" selected={!isYearPage}>연도 선택</option>
  
  {years.map(year => {
    const yearPath = `/${year}/`;
    const isSelected = currentPath.startsWith(yearPath);

    return (
      <option value={yearPath} selected={isSelected}>
        {year}학년도
      </option>
    );
  })}
</select>

<script>
  const switcher = document.getElementById('year-switcher');

  if (switcher) {
    switcher.addEventListener('change', (event) => {
      const target = event.target as HTMLSelectElement;
      
      // 2. 방어적 프로그래밍: 선택된 값이 빈 문자열("")이 아닐 때만 페이지를 이동합니다.
      if (target.value !== "") {
        window.location.href = target.value;
      }
    });
  }
</script>