---
// src/layouts/PostLayout.astro
import MainLayout from "./MainLayout.astro";

// Astro는 마크다운 렌더링 시 frontmatter와 headings 배열을 자동으로 props로 전달합니다.
const { frontmatter, headings } = Astro.props;

// Svelte 코드처럼 h2와 h3만 필터링합니다. (Astro에서는 level 대신 depth를 사용합니다)
const filteredHeadings = headings.filter(
  (h: any) => h.depth === 2 || h.depth === 3,
);
---

<MainLayout title={frontmatter.title || "수업 기록"}>
  <div class="container-fluid px-md-5 mt-5 mb-5">
    <div class="row justify-content-center">
      <div class="col-12 col-lg-10 col-xl-10">
        <div class="mb-4">
          <a
            href="javascript:history.back()"
            class="text-decoration-none text-muted small"
          >
            <span class="me-1">←</span> 목록으로 돌아가기
          </a>
        </div>
        <div class="mb-5">
          <h1 class="fw-bold mb-3">{frontmatter.title}</h1>
          {
            frontmatter.date && (
              <div class="text-muted small">
                <span>📅 작성일: {frontmatter.date}</span>
              </div>
            )
          }
        </div>

        <div
          class="markdown-body shadow-sm p-4 p-md-5 rounded border w-100"
          style="max-width: 100%;"
        >
          <slot />
        </div>

        <div class="mt-5 text-center">
          <hr class="mb-5" />
          <a
            href="javascript:history.back()"
            class="btn btn-outline-dark px-4 rounded-pill"
          >
            목록으로 돌아가기
          </a>
        </div>
      </div>

      <div class="d-none d-lg-block col-lg-2 col-xl-2 ps-lg-4">
        <div class="sticky-top pt-2" style="top: 80px;">
          <h6
            class="fw-bold text-muted mb-3 text-uppercase"
            style="letter-spacing: 1px; font-size: 0.85rem;"
          >
            📝 Outline
          </h6>
          <nav class="nav flex-column outline-nav">
            {
              filteredHeadings.map((heading: any) => (
                <a
                  class={`nav-link text-muted py-1 ${heading.depth === 3 ? "ms-3 small" : "fw-semibold"}`}
                  href={`#${heading.slug}`}
                >
                  {heading.text}
                </a>
              ))
            }
          </nav>
        </div>
      </div>
    </div>
  </div>
</MainLayout>

<style>
  .markdown-body {
    transition:
      background-color 0.3s ease,
      color 0.3s ease;
  }

  .outline-nav .nav-link {
    transition:
      color 0.2s ease,
      background-color 0.2s ease,
      transform 0.2s ease;
    border-radius: 6px;
    font-size: 0.95rem;
  }

  .outline-nav .nav-link:hover {
    color: var(--bs-primary) !important;
    background-color: var(--bs-light);
    transform: translateX(3px);
  }
</style>

<style is:global>
  /* markdown-body 컨테이너 내부의 모든 이미지에 적용 */
  .markdown-body img {
    max-width: 100%; /* 부모 너비를 넘지 않도록 제한 */
    height: auto; /* 비율에 맞게 높이 자동 조절 */
    display: block; /* 여백 계산을 깔끔하게 하기 위해 블록 요소로 변경 */
    margin: 1.5rem auto; /* 상하 여백을 주고 가운데 정렬 (원준님 취향에 맞게 조절 가능) */
    border-radius: 0.375rem; /* Bootstrap의 rounded 클래스처럼 모서리를 둥글게 (선택 사항) */
  }

  /* 1. 마크다운 테이블 기본 구조를 Bootstrap 스타일로 강제 적용 */
/* [공통] 테이블 레이아웃 안정화 (사이즈 변화 방지) */
  .markdown-body table {
    width: 100% !important;
    table-layout: auto !important; /* 내용에 맞춰 크기 조절 */
    border-collapse: collapse !important;
    margin: 1.5rem 0 !important;
  }

  /* 2. 헤더(th) 및 셀(td) 디자인 */
  .markdown-body table th,
  .markdown-body table td {
    padding: 0.75rem !important; /* 여백 확보 */
    border: 1px solid var(--bs-border-color) !important; /* 내부 선(Lines) 추가 */
    vertical-align: middle !important;
    text-align: center !important;
    color: var(--bs-body-color) !important;
  }

  /* 3. 헤더 배경색 강조 (선택 사항) */
  .markdown-body table thead th {
    background-color: var(--bs-tertiary-bg) !important;
    font-weight: 700 !important;
  }

  /* 4. 마우스 호버(Hover) 효과 추가 */
  .markdown-body table tbody tr {
    transition: background-color 0.2s ease !important;
  }

  .markdown-body table tbody tr:hover {
    background-color: var(
      --bs-tertiary-bg
    ) !important; /* Bootstrap Hover 효과 재현 */
    cursor: default;
  }

  /* 5. 모바일 가로 스크롤 대응 (테이블이 너무 클 경우) */
  .markdown-body div.table-wrapper {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

/* --------------------------------------------------
     DARK THEME 전용 스타일 (라이트 테마는 영향 없음)
  -------------------------------------------------- */

  /* 1. 다크 테마 시 th (헤더) 배경 진하게 + 글자 흰색 */
  [data-bs-theme="dark"] .markdown-body table thead th {
    background-color: #212529 !important; /* Bootstrap Dark 배경색 */
    color: #ffffff !important;            /* 글자색 흰색 */
    border-color: var(--bs-border-color) !important;
  }

  /* 2. 다크 테마 시 td (본문) 글자색 흰색 */
  [data-bs-theme="dark"] .markdown-body table td {
    color: #ffffff !important;            /* 본문 글자색 흰색 */
    border-color: var(--bs-border-color) !important;
    background-color: transparent !important;
  }

  /* 3. 다크 테마 시 호버 효과 조정 */
  [data-bs-theme="dark"] .markdown-body table tbody tr:hover {
    background-color: rgba(255, 255, 255, 0.075) !important;
  }

  /* 4. 다크 테마 시 줄무늬(Striped) 배경색 초기화 (방해 금지) */
  [data-bs-theme="dark"] .markdown-body table tr:nth-child(2n) {
    background-color: transparent !important;
  }  
</style>
