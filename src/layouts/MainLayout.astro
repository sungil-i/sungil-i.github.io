---
// src/layouts/MainLayout.astro
import YearSelector from '../components/YearSelector.astro'; // 컴포넌트 불러오기

interface Props {
	title?: string;
}

const { title = "성일고 정보 수업" } = Astro.props;
---

<!DOCTYPE html>
<html lang="ko">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
		<style>
			/* 가독성을 위한 Pretendard 폰트 예시 */
			@import url('https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard.css');
			body { font-family: Pretendard, sans-serif; }
			.content-area { min-height: 85vh; }
		</style>
	</head>
	<body>
		<header class="p-3 bg-dark text-white border-bottom border-secondary">
			<div class="container">
				<div class="d-flex flex-wrap align-items-center justify-content-center justify-content-lg-start">
					<a href="/" class="d-flex align-items-center mb-2 mb-lg-0 text-white text-decoration-none h4 me-4">
						🏫 성일정보고등학교 박원준T.
					</a>

					<ul class="nav col-12 col-lg-auto me-lg-auto mb-2 justify-content-center mb-md-0">
						</ul>

					<div class="text-end col-12 col-lg-auto">
						<YearSelector />
					</div>
				</div>
			</div>
		</header>

		<main class="container my-5 content-area">
			<div class="row">
				<div class="col-12">
					<slot /> </div>
			</div>
		</main>

		<footer class="py-4 bg-light text-center border-top">
			<div class="container">
				<p class="text-muted mb-0">© 2026 Wonjun - 성일고등학교 정보 수업 자료실</p>
			</div>
		</footer>

		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
	</body>
</html>