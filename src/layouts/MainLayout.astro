---
// src/layouts/MainLayout.astro
import YearSelector from "../components/YearSelector.astro"; // 컴포넌트 불러오기
import ThemeToggle from "../components/ThemeToggle.astro";

interface Props {
	title?: string;
}

const { title = "성일정보고등학교 박원준T." } = Astro.props;
---

<!doctype html>
<html lang="ko">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
		<link
			href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
			rel="stylesheet"
		/>
		<style is:global>
			/* ----------------------------------------------------
				1. ThemeToggle 아이콘 색상 문제 해결
			---------------------------------------------------- */
			/* 헤더가 항상 bg-dark이므로, Light/Dark 모드 상관없이 아이콘을 강제로 흰색으로 고정합니다. */
			.theme-toggle {
				color: #ffffff !important;
			}

			/* ----------------------------------------------------
				2. ClassLayout 리스트 그룹(list-group) 다크모드 대응
			---------------------------------------------------- */
			/* 다크모드일 때 리스트 아이템의 배경을 어둡게, 글자는 밝게 덮어씁니다. */
			html.dark .list-group-item {
				background-color: #212529 !important; /* Bootstrap 다크 배경색 */
				color: #f8f9fa !important; /* 밝은 텍스트 색상 */
				border-color: #373b3e !important; /* 어두운 테두리 색상 */
			}

			/* ----------------------------------------------------
     3. PostLayout 텍스트 가독성 개선 (뒤로가기, 작성일, Outline)
     ---------------------------------------------------- */
			/* 다크모드일 때 text-muted 클래스와 일반 span 태그들의 색상을 밝은 회색으로 변경합니다. */
			html.dark .text-muted,
			html.dark span.me-1,
			html.dark span {
				color: #dee2e6 !important;
			}

			/* Outline 제목 등 h6 태그의 가독성 확보 */
			html.dark h6.text-muted {
				color: #f8f9fa !important;
			}

			/* 뒤로가기 링크 등 다크모드에서의 일반 링크 색상 (밝은 파란색) */
			html.dark a {
				color: #6ea8fe;
			}

			/* 헤더 안의 링크는 파란색으로 변하지 않도록 흰색으로 유지 */
			html.dark header a {
				color: #ffffff !important;
			}
		</style>
		<style>
			/* 가독성을 위한 Pretendard 폰트 예시 */
			@import url("https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard.css");
			body {
				font-family: Pretendard, sans-serif;
			}
			.content-area {
				min-height: 85vh;
			}
			/* 글로벌 CSS 변수 정의 */
			:root {
				--bg-color: #ffffff;
				--text-color: #222222;
				--link-color: #0056b3;
			}
			html.dark {
				--bg-color: #1a1a1a;
				--text-color: #e0e0e0;
				--link-color: #4da3ff;
			}
			body {
				background-color: var(--bg-color);
				color: var(--text-color);
				transition:
					background-color 0.3s ease,
					color 0.3s ease;
			}
			a {
				color: var(--link-color);
			}
		</style>

		<script is:inline>
			const theme = (() => {
				if (
					typeof localStorage !== "undefined" &&
					localStorage.getItem("theme")
				) {
					return localStorage.getItem("theme");
				}
				if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
					return "dark";
				}
				return "light";
			})();

			if (theme === "light") {
				document.documentElement.classList.remove("dark");
			} else {
				document.documentElement.classList.add("dark");
			}
			window.localStorage.setItem("theme", theme);
		</script>
	</head>
	<body>
		<header class="p-3 bg-dark text-white border-bottom border-secondary">
			<div class="container">
				<div
					class="d-flex flex-wrap align-items-center justify-content-center justify-content-lg-start"
				>
					<a
						href="/"
						class="d-flex align-items-center mb-2 mb-lg-0 text-white text-decoration-none h4 me-4"
					>
						🏫 성일정보고등학교 박원준 선생님
					</a>

					<ul
						class="nav col-12 col-lg-auto me-lg-auto mb-2 justify-content-center mb-md-0"
					>
					</ul>

					<div class="text-end col-12 col-lg-auto d-flex align-items-center justify-content-end gap-3">
						<YearSelector />
						<ThemeToggle />
					</div>
				</div>
			</div>
		</header>

		<main class="container my-5 content-area">
			<div class="row">
				<div class="col-12">
					<slot />
				</div>
			</div>
		</main>

		<footer class="py-4 bg-light text-center border-top">
			<div class="container">
				<p class="text-muted mb-0">
					© 2026 원준샘 - 성일정보고등학교 수업 자료실
				</p>
			</div>
		</footer>

		<script
			src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
		></script>
	</body>
</html>
