---
// src/layouts/ClassLayout.astro
import MainLayout from './MainLayout.astro'; // MainLayout을 상속받음

interface Props {
  frontmatter: {
    title: string;
    classId: string; // 마크다운에서 전달받을 학급 ID (예: '2-10')
  };
}

const { frontmatter } = Astro.props;
const currentYear = Astro.url.pathname.split('/')[1]; // URL에서 연도 추출 (예: '2026')
const classFolder = `${currentYear}/${frontmatter.classId}`; // 폴더 경로 조합

// --- [핵심 핵심] daily/test 파일 자동 목록 및 정렬 로직 ---

// 1. 해당 학급의 모든 마크다운 파일을 가져옵니다.
const allClassContent = await Astro.glob('../pages/**/*.md');

// 2. daily 폴더 파일 필터링 및 이름 내림차순 정렬 (최신글이 위로)
const dailyPosts = allClassContent
  .filter(post => post.url?.includes(`/pages/${classFolder}/daily/`))
  .sort((a, b) => {
    const fileA = a.file.split('/').pop() || '';
    const fileB = b.file.split('/').pop() || '';
    return fileB.localeCompare(fileA); // 파일 이름 내림차순
  });

// 3. test 폴더 파일 필터링 및 이름 오름차순 정렬 (1차 -> 2차 순서대로)
const testPosts = allClassContent
  .filter(post => post.url?.includes(`/pages/${classFolder}/test/`))
  .sort((a, b) => {
    const fileA = a.file.split('/').pop() || '';
    const fileB = b.file.split('/').pop() || '';
    return fileA.localeCompare(fileB); // 파일 이름 오름차순
  });

---

<MainLayout title={`${frontmatter.title} (${frontmatter.classId})`}>
  <div class="row">
    <div class="col-md-7 border-end">
      <h2 class="h3 text-primary mb-4 border-bottom pb-2">📅 매일 수업 기록</h2>
      {dailyPosts.length > 0 ? (
        <div class="list-group list-group-flush">
          {dailyPosts.map(post => (
            <a href={post.url} class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
              {post.frontmatter.title || post.file.split('/').pop()?.replace('.md', '')}
              <span class="badge bg-secondary rounded-pill">수업</span>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-muted">아직 등록된 수업 기록이 없습니다.</p>
      )}
    </div>

    <div class="col-md-5 ps-md-4">
      <h2 class="h3 text-success mb-4 border-bottom pb-2">📝 수행평가 & 테스트</h2>
      {testPosts.length > 0 ? (
        <div class="list-group list-group-flush small">
          {testPosts.map(post => (
            <a href={post.url} class="list-group-item list-group-item-action">
              {post.frontmatter.title || post.file.split('/').pop()?.replace('.md', '')}
            </a>
          ))}
        </div>
      ) : (
        <p class="text-muted">등록된 수행평가 계획이 없습니다.</p>
      )}
    </div>
  </div>

  <div class="mt-5 pt-4 border-top">
    <slot /> </div>
</MainLayout>