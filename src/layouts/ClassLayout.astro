---
// src/layouts/ClassLayout.astro
import MainLayout from './MainLayout.astro'; 

interface Props {
  frontmatter: {
    title: string;
    classId: string; 
  };
}

const { frontmatter } = Astro.props;
const currentYear = Astro.url.pathname.split('/')[1]; 
const classFolder = `${currentYear}/${frontmatter.classId}`; 

// --- [수정된 핵심 로직: Astro.glob 대신 import.meta.glob 사용] ---

// 1. Vite 네이티브 함수를 사용하여 마크다운 파일들을 즉시(eager) 불러옵니다.
const pages = import.meta.glob('../pages/**/*.md', { eager: true });

// 2. 가져온 모듈 객체를 배열 형태로 변환합니다. (타입 단언 추가)
const allClassContent = Object.values(pages) as any[];

// 3. daily 폴더 파일 필터링 및 이름 내림차순 정렬 (최신글이 위로)
const dailyPosts = allClassContent
  .filter(post => post.url?.includes(`/${classFolder}/daily/`))
  .sort((a, b) => {
    // Vite 모듈은 file 경로를 가지고 있으므로 이를 기준으로 정렬합니다.
    const fileA = a.file?.split('/').pop() || '';
    const fileB = b.file?.split('/').pop() || '';
    return fileB.localeCompare(fileA); 
  });

// 4. test 폴더 파일 필터링 및 이름 오름차순 정렬 (1차 -> 2차 순서대로)
const testPosts = allClassContent
  .filter(post => post.url?.includes(`/${classFolder}/test/`))
  .sort((a, b) => {
    const fileA = a.file?.split('/').pop() || '';
    const fileB = b.file?.split('/').pop() || '';
    return fileA.localeCompare(fileB); 
  });
---

<MainLayout title={`${frontmatter.title} (${frontmatter.classId})`}>
  <div class="mb-5 pt-4 border-bottom">
    <slot /> </div>
    
  <div class="row">
    <div class="col-md-7 border-end">
      <h2 class="h3 text-primary mb-4 border-bottom pb-2">📅 매일 수업 기록</h2>
      {dailyPosts.length > 0 ? (
        <div class="list-group list-group-flush">
          {dailyPosts.map(post => (
            <a href={post.url} class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
              {post.frontmatter.title || post.file?.split('/').pop()?.replace('.md', '')}
              <span class="badge bg-secondary rounded-pill">수업</span>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-muted">아직 등록된 수업 기록이 없습니다.</p>
      )}
    </div>

    <div class="col-md-5 ps-md-4">
      <h2 class="h3 text-success mb-4 border-bottom pb-2">📝 노트 & 수행평가</h2>
      {testPosts.length > 0 ? (
        <div class="list-group list-group-flush small">
          {testPosts.map(post => (
            <a href={post.url} class="list-group-item list-group-item-action">
              {post.frontmatter.title || post.file?.split('/').pop()?.replace('.md', '')}
            </a>
          ))}
        </div>
      ) : (
        <p class="text-muted">등록된 수행평가 계획이 없습니다.</p>
      )}
    </div>
  </div>
</MainLayout>